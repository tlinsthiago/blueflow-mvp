generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
  collaborator
}

enum VisitStatus {
  scheduled
  in_progress
  completed
  pending
  cancelled
}

enum ChecklistStatus {
  normal
  attention
  critical
}

enum FileType {
  reservoir_photo
  pump_photo
  electrical_panel_photo
  signed_acceptance_term
  signed_contract
  technical_report_pdf
  other
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(collaborator)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model CompanySettings {
  id                  String   @id @default(uuid())
  legalName           String
  cnpj                String?
  addressLine         String?
  city                String?
  state               String?
  legalRepresentative String?
  representativeCpf   String?
  phone               String?
  email               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("company_settings")
}

model Condominium {
  id           String     @id @default(uuid())
  name         String
  legalName    String?
  cnpj         String?
  addressLine  String?
  city         String?
  state        String?
  managerName  String?
  managerCpf   String?
  managerPhone String?
  managerEmail String?
  units        Int        @default(0)
  monthlyWindow String?
  status        String     @default("Ativo")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  visits       Visit[]
  contracts    Contract[]

  @@map("condominiums")
}

model Technician {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  role      String?
  status    String   @default("Ativo")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  visits    Visit[]

  @@map("technicians")
}

model Visit {
  id               String               @id @default(uuid())
  condominiumId    String
  technicianId     String
  serviceType      String
  status           VisitStatus          @default(scheduled)
  visitDate        DateTime
  responsibleName  String?
  responsibleRole  String?
  acceptanceConfirmed Boolean              @default(false)
  acceptanceResponsibleName String?
  acceptanceResponsibleRole String?
  installationLocation String?
  equipmentValue   Decimal?             @db.Decimal(12, 2)
  acceptanceNotes  String?
  notes            String?
  actionsPerformed String?
  issuesFound      String?
  improvementsSuggested String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  condominium      Condominium          @relation(fields: [condominiumId], references: [id], onDelete: Restrict)
  technician       Technician           @relation(fields: [technicianId], references: [id], onDelete: Restrict)
  checklistItems   VisitChecklistItem[]
  photos           VisitPhoto[]
  files            File[]
  report           Report?

  @@index([condominiumId])
  @@index([technicianId])
  @@index([status])
  @@index([visitDate])
  @@map("visits")
}

model VisitChecklistItem {
  id        String          @id @default(uuid())
  visitId   String
  equipment String
  status    ChecklistStatus @default(normal)
  notes     String?
  visit     Visit           @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("visit_checklist_items")
}

model VisitPhoto {
  id        String   @id @default(uuid())
  visitId   String
  fileId    String?
  fileName  String
  fileUrl   String?
  createdAt DateTime @default(now())
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  file      File?    @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([visitId])
  @@index([fileId])
  @@map("visit_photos")
}

model Report {
  id          String   @id @default(uuid())
  visitId     String   @unique
  fileId      String?  @unique
  version     Int      @default(1)
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  visit       Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  file        File?    @relation("ReportFile", fields: [fileId], references: [id], onDelete: SetNull)

  @@index([fileId])
  @@map("reports")
}

model Contract {
  id                      String      @id @default(uuid())
  condominiumId           String
  contractNumber          String
  serviceType             String
  monthlyValue            Decimal?    @db.Decimal(12, 2)
  dueDay                  Int?
  termMonths              Int?
  startDate               DateTime?
  signatureDate           DateTime?
  monthlyPreventiveVisits Int?
  emergencySlaHours       Int?
  nonEmergencySlaHours    Int?
  jurisdiction            String?
  status                  String      @default("Rascunho")
  notes                   String?
  signedFileId            String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  condominium             Condominium @relation(fields: [condominiumId], references: [id], onDelete: Restrict)
  signedFile              File?       @relation("ContractSignedFile", fields: [signedFileId], references: [id], onDelete: SetNull)

  @@index([condominiumId])
  @@index([signedFileId])
  @@map("contracts")
}

model File {
  id              String       @id @default(uuid())
  visitId         String?
  fileName        String
  fileType        FileType     @default(other)
  mimeType        String
  storageKey      String
  url             String?
  size            Int?
  uploadedAt      DateTime     @default(now())
  uploadedBy      String?
  publicUrl       String?
  sizeBytes       Int?
  category        String?
  createdAt       DateTime     @default(now())
  visit           Visit?       @relation(fields: [visitId], references: [id], onDelete: Cascade)
  visitPhotos     VisitPhoto[]
  signedContracts Contract[]   @relation("ContractSignedFile")
  reports         Report[]     @relation("ReportFile")

  @@index([visitId])
  @@index([fileType])
  @@map("files")
}
