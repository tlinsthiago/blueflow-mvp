DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/blueflow?sslmode=require"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1h"

# Dominios permitidos pelo CORS, separados por virgula.
# Em producao, inclua o dominio do frontend publicado na Vercel e o dominio customizado.
CORS_ORIGINS="http://localhost:5173,http://localhost:4173,https://SEU-FRONTEND.vercel.app,https://ftecautomacao.com.br,https://www.ftecautomacao.com.br"

# Uso local. Na Vercel, PORT/HOST sao gerenciados pela plataforma.
PORT=3333
HOST="0.0.0.0"

SEED_ADMIN_EMAIL="admin@blueflow.local"
SEED_ADMIN_PASSWORD="Admin123!"
SEED_MANAGER_EMAIL="gestor@blueflow.local"
SEED_MANAGER_PASSWORD="Gestor123!"
SEED_COLLABORATOR_EMAIL="colaborador@blueflow.local"
SEED_COLLABORATOR_PASSWORD="Colaborador123!"
